#### Step 2.5 — DB Connection Files Created

**`lib/db-prod.ts`** — Read-only Prod Postgres
```typescript
import { Pool } from 'pg'
const prodPool = new Pool({ connectionString: process.env.PROD_DATABASE_URL })
export async function queryProd(text: string, params?: (string|number|boolean|null)[]) {
  const client = await prodPool.connect()
  try { return await client.query(text, params) }
  finally { client.release() }
}
```

**`lib/db-own.ts`** — Own Docker Postgres
```typescript
import { Pool } from 'pg'
const ownPool = new Pool({ connectionString: process.env.OWN_DATABASE_URL })
export async function queryOwn(text: string, params?: (string|number|boolean|null)[]) {
  const client = await ownPool.connect()
  try { return await client.query(text, params) }
  finally { client.release() }
}
```

**`lib/clickhouse.ts`** — ClickHouse via VPN
```typescript
import { createClient } from '@clickhouse/client'
const clickhouse = createClient({
  host: process.env.CLICKHOUSE_HOST!,
  username: process.env.CLICKHOUSE_USER!,
  password: process.env.CLICKHOUSE_PASSWORD!,
})
export default clickhouse
```

